<Window x:Class="AthleteBMI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Athlete BMI" Height="450" Width="400"
        Background="#0F172A">

    <Grid Margin="20">
        <Border Background="#1E293B" CornerRadius="20" Padding="20">
            <StackPanel>

                <TextBlock Text="🏋️ Athlete BMI"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Height (cm)" Foreground="White"/>
                <TextBox x:Name="HeightBox" Margin="0,5,0,10" Height="30"
                         Background="#334155" Foreground="White"/>

                <TextBlock Text="Weight (kg)" Foreground="White"/>
                <TextBox x:Name="WeightBox" Margin="0,5,0,20" Height="30"
                         Background="#334155" Foreground="White"/>

                <Button Content="Calculate BMI"
                        Height="40"
                        Background="#22C55E"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="CalculateBMI_Click"/>

                <TextBlock x:Name="ResultText"
                           FontSize="18"
                           Foreground="#38BDF8"
                           Margin="0,20,0,0"
                           TextAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
